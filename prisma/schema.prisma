generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  students     Student[]
  tests        Test[]
  submissions  Submission[]

  @@map("users")
}

model Student {
  id            String   @id @default(cuid())
  teacherId     String
  name          String
  className     String
  rollNumber    String?
  guardianEmail String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  teacher       User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  submissions   Submission[]

  @@index([teacherId, name])
  @@unique([teacherId, rollNumber])
  @@map("students")
}

model Test {
  id              String           @id @default(cuid())
  teacherId       String
  title           String
  subject         String
  className       String
  testDate        DateTime
  totalMarks      Int
  status          TestStatus       @default(DRAFT)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  teacher         User             @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  rubricQuestions RubricQuestion[]
  submissions    Submission[]

  @@index([teacherId, testDate])
  @@map("tests")
}

model RubricQuestion {
  id             String @id @default(cuid())
  testId         String
  position       Int
  label          String
  prompt         String
  expectedAnswer String
  criteria       String
  maxMarks       Int
  test           Test   @relation(fields: [testId], references: [id], onDelete: Cascade)
  evaluations    EvaluationQuestion[]

  @@unique([testId, position])
  @@map("rubric_questions")
}

enum TestStatus {
  DRAFT
}

model Submission {
  id               String           @id @default(cuid())
  teacherId        String
  testId           String
  studentId        String
  fileKey          String           @unique
  fileName         String
  mimeType         String
  fileSizeBytes    Int
  processingStatus ProcessingStatus @default(UPLOADED)
  processingError  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  teacher          User             @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  test             Test             @relation(fields: [testId], references: [id], onDelete: Cascade)
  student          Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  evaluation       Evaluation?

  @@index([teacherId, createdAt])
  @@index([testId, studentId])
  @@map("submissions")
}

model Evaluation {
  id                  String               @id @default(cuid())
  submissionId        String               @unique
  status              EvaluationStatus     @default(DRAFT)
  totalSuggestedMarks Int                  @default(0)
  totalFinalMarks     Int                  @default(0)
  overallFeedback     String?
  finalizedAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  submission          Submission           @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questions           EvaluationQuestion[]
  commentThreads      CommentThread[]
  versions            EvaluationVersion[]

  @@map("evaluations")
}

model EvaluationQuestion {
  id                    String         @id @default(cuid())
  evaluationId          String
  rubricQuestionId      String
  earnedMarksSuggested  Int
  earnedMarksFinal      Int
  rationale             String
  answerContentJson     Json
  evaluation            Evaluation     @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  rubricQuestion        RubricQuestion @relation(fields: [rubricQuestionId], references: [id], onDelete: Restrict)
  commentThreads        CommentThread[]

  @@unique([evaluationId, rubricQuestionId])
  @@map("evaluation_questions")
}

model CommentThread {
  id           String        @id @default(cuid())
  evaluationId String
  questionId   String?
  anchorJson   Json
  status       CommentStatus @default(OPEN)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  evaluation   Evaluation    @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  question     EvaluationQuestion? @relation(fields: [questionId], references: [id], onDelete: SetNull)
  comments     Comment[]

  @@map("comment_threads")
}

model Comment {
  id        String     @id @default(cuid())
  threadId  String
  body      String
  authorType CommentAuthorType
  createdAt DateTime   @default(now())
  thread    CommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model EvaluationVersion {
  id           String     @id @default(cuid())
  evaluationId String
  version      Int
  snapshot     Json
  createdAt    DateTime   @default(now())
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, version])
  @@map("evaluation_versions")
}

enum ProcessingStatus {
  UPLOADED
  QUEUED
  EXTRACTING
  EVALUATING
  READY
  FAILED
}

enum EvaluationStatus {
  DRAFT
  FINALIZED
}

enum CommentStatus {
  OPEN
  RESOLVED
  ORPHANED
}

enum CommentAuthorType {
  AI
  TEACHER
}
