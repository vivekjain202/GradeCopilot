# Direct Supabase Postgres connection strings. Keep these server-only.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Public application origin, used for links and browser-safe configuration.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
SESSION_SECRET="replace-with-a-random-32-byte-secret"

SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"

# OpenAI powers handwriting transcription and draft evaluation. Keep server-only.
OPENAI_API_KEY="replace-with-openai-api-key"
# Optional: defaults to gpt-5.6. Use a model available to your OpenAI project.
OPENAI_MODEL="gpt-5.6"

# Generate with: openssl rand -base64 32. Required by Vercel Cron in production.
CRON_SECRET="replace-with-another-random-32-byte-secret"
